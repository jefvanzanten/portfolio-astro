---
import Layout from "../Layout.astro";
import CommitWidget from "../components/CommitWidget/CommitWidget.astro";
import FeaturedProjects from "../components/FeaturedProjects/FeaturedProjects";
import GithubLink from "../components/GithubLink/GithubLink.astro";
import { projects } from "../data.ts";
const filteredProjects = projects.filter((project) => project.highlighted);
const ctaLinks = [
  {
    name: "Mail mij",
    iconUrl: "/icons/mail-outline.svg",
    url: "mailto:j.van.zanten@mail.com",
    variant: "primary",
  },
  {
    name: "GitHub",
    iconUrl: "/icons/github-mark-white.svg",
    url: "https://github.com/jefvanzanten",
  },
  {
    name: "LinkedIn",
    iconUrl: "/icons/linkedin.svg",
    url: "https://www.linkedin.com/in/jefvanzanten/",
  },
  {
    name: "Projecten",
    iconUrl: "/icons/folder-open.svg",
    url: "/projects",
  },
] as const;
---

<Layout
  title="Home - jefvanzanten.dev"
  description="Portfolio van Jef (Jeffrey) van Zanten - Fullstack developer | React, Next.js, Svelte, Typescript, Convex, Hono, Drizzle, PostgreSQL."
>
  <div class="content-container">
    <section class="introduction">
      <div class="introduction-content">
        <div class="title introduction-title">
          <span class="line"></span>
          <h1>Full-stack developer</h1>
          <span class="line"></span>
        </div>
        <p>
          Hey, mijn naam is Jef. Momenteel volg ik de studie Software
          Development (HBO Associate Degree).
          <br />
          <br />
          Ik wissel met programmeren tussen frontend, backend en mobile projecten,
          zodat mijn kennis en vaardigheden op elk vlak blijven ontwikkelen.
        </p>
        <div class="cta-row">
          {
            ctaLinks.map((link) => (
              <GithubLink
                name={link.name}
                iconUrl={link.iconUrl}
                url={link.url}
                variant={link.variant}
              />
            ))
          }
        </div>
      </div>
    </section>
    <CommitWidget />
    <section class="featured-projects-container">
      <div class="title">
        <span class="line"></span>
        <h1>Uitgelichte Projecten</h1>
        <span class="line"></span>
      </div>
      <FeaturedProjects client:load projects={filteredProjects} />
    </section>
  </div>
</Layout>

<style>
  .content-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    z-index: 0;
    overflow: hidden;
    width: 100%;
    --home-section-width: min(100%, calc(var(--card-width) * 3 + 240px));
    --featured-projects-container-width: var(--home-section-width);

    @media screen and (max-width: 940px) {
      padding: 0 10vw;
    }
  }

  /* Introduction section */

  .introduction {
    padding: 4em;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;

    @media screen and (max-width: 940px) {
      min-height: 20vh;
    }

    @media screen and (min-width: 1800px) {
      min-height: 10vh;
    }
  }

  .introduction-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(100%, 42rem);
    gap: 1.75rem;
    text-align: center;

    h1 {
      font-family: var(--font-display);
      font-weight: 100;
      font-size: 1.3rem;
      text-wrap: nowrap;
      padding-top: 1em;
    }

    p {
      font-size: 1.1rem;
      margin: 0;
      color: var(--text-muted);
      text-wrap: wrap;
      max-width: 36rem;
      padding: 0;

      @media screen and (max-width: 940px) {
        font-size: 1rem;
        max-width: 24rem;
      }

      @media screen and (min-width: 1800px) {
        font-size: 0.9rem;
        max-width: 28rem;
      }
    }
  }

  .introduction-title {
    width: 100%;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
    justify-content: center;
    max-width: 42rem;
  }

  /* Featured Projects */

  .featured-projects-container {
    display: flex;
    flex-direction: column;
    gap: 2em;
    padding: 5vh 0;
    width: var(--home-section-width);

    @media screen and (orientation: portrait) and (max-width: 1024px) {
      align-items: center;
    }
  }

  .featured-projects-container .title .line {
    border-bottom: none;
    flex: 1 1 auto;
    min-width: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.1),
      rgba(255, 255, 255, 0.5),
      rgba(255, 255, 255, 0.1)
    );
  }

  @media screen and (max-width: 640px) {
    .cta-row {
      width: 100%;
    }

    .cta-row :global(a) {
      flex: 1 1 calc(50% - 0.45rem);
    }
  }

</style>
