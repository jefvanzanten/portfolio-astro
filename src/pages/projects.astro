---
import Layout from "../Layout.astro";
import ProjectCard from "../components/ProjectCard/ProjectCard.astro";
import { projects } from "../data.ts";
import type { Category, Language, Library } from "../types/project";

const allTech = [...new Set(projects.flatMap((project) => [...project.languages, ...project.libraries]))].join(", ");
const description = `Projecten van Jef (Jeffrey) van Zanten - Fullstack developer. Technologieen: ${allTech}.`;
const selectedCategories = new Set(Astro.url.searchParams.getAll("category"));
const selectedLanguages = new Set(Astro.url.searchParams.getAll("language"));
const selectedLibraries = new Set(Astro.url.searchParams.getAll("library"));

const categoryOrder: Category[] = [
  "Frontend",
  "Backend",
  "Fullstack",
  "Mobile",
  "Desktop",
];

const categories = categoryOrder.filter((category) =>
  projects.some((project) => project.category === category),
);
const languages = [...new Set(projects.flatMap((project) => project.languages))].sort() as Language[];
const libraries = [...new Set(projects.flatMap((project) => project.libraries))].sort() as Library[];
---

<Layout
  title="Projects - jefvanzanten.dev"
  description={description}
>
  <section class="projects-page">
    <div class="content-container" data-projects-root data-filters-open="true">
      <section class="filters">
        <div class="title-row">
          <button
            type="button"
            class="filter-toggle"
            aria-expanded="true"
            aria-controls="project-filter-panel"
            data-filter-toggle
          >
            Verberg filters
          </button>
        </div>

        <form
          id="project-filter-panel"
          class="filter-form"
          data-filter-form
          data-filter-panel
        >
          <fieldset class="filter-group">
            <legend>Categorie</legend>
            <div class="filter-options filter-options-compact">
              {
                categories.map((category) => (
                  <label class="filter-option">
                    <input
                      type="checkbox"
                      name="category"
                      value={category}
                      checked={selectedCategories.has(category)}
                    />
                    <span>{category}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <fieldset class="filter-group">
            <legend>Programmeertalen</legend>
            <div class="filter-options filter-options-compact">
              {
                languages.map((language) => (
                  <label class="filter-option">
                    <input
                      type="checkbox"
                      name="language"
                      value={language}
                      checked={selectedLanguages.has(language)}
                    />
                    <span>{language}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <fieldset class="filter-group">
            <legend>Frameworks & libraries</legend>
            <div class="filter-options filter-options-libraries">
              {
                libraries.map((library) => (
                  <label class="filter-option">
                    <input
                      type="checkbox"
                      name="library"
                      value={library}
                      checked={selectedLibraries.has(library)}
                    />
                    <span>{library}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>
        </form>
      </section>

      <p class="empty-state" data-project-empty hidden>
        Geen projecten gevonden met deze filters.
      </p>

      <section class="project-container" data-project-list>
        {
          projects.map((project, index) => (
            <ProjectCard project={project} index={index} priority={index < 3} />
          ))
        }
      </section>
    </div>

    <dialog class="project-image-modal" data-project-modal>
      <div class="project-image-frame">
        <button
          type="button"
          class="project-image-close"
          aria-label="Sluit screenshot"
          data-project-modal-close
        >
          X
        </button>
        <img
          src=""
          alt="Project screenshot"
          class="project-image"
          data-project-modal-image
        />
      </div>
    </dialog>
  </section>

  <script>
    import { setupProjectsPage } from "../scripts/projectsPage";

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupProjectsPage, {
        once: true,
      });
    } else {
      setupProjectsPage();
    }

    document.addEventListener("astro:page-load", setupProjectsPage);
  </script>

  <style>
  .projects-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding-bottom: 8vh;
  }

  .content-container {
    width: min(100%, calc(var(--card-width) * 3 + 240px));
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .filters {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem 0 0.5rem;
  }

  .title-row {
    display: flex;
    justify-content: flex-start;
    gap: 1rem;
  }

  .filter-toggle {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in oklch, var(--card-bg), #000 8%);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 0.85rem;
    padding: 0.7rem 1rem;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease,
      background 0.15s ease;
  }

  .filter-toggle:hover {
    border-color: var(--border-bright);
    transform: translateY(-1px);
  }

  .filter-form {
    display: grid;
    grid-template-columns: minmax(210px, 0.85fr) minmax(230px, 1fr) minmax(440px, 1.8fr);
    gap: 1rem;
    align-items: stretch;
  }

  .filter-form[hidden] {
    display: none;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1rem 1.1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: color-mix(in oklch, var(--card-bg), #000 18%);
    height: 100%;
  }

  .filter-group legend {
    padding: 0 0.4rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--text-bright);
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .filter-options-compact {
    flex: 1 1 auto;
    align-items: center;
    justify-content: center;
  }

  .filter-options-libraries {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: start;
  }

  .filter-options-libraries .filter-option {
    padding: 0.45rem 0.65rem;
    font-size: 0.82rem;
  }

  .filter-option {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    cursor: pointer;
    user-select: none;
    font-size: 0.9rem;
    width: 100%;
  }

  .filter-options-compact .filter-option {
    width: min(100%, 14rem);
  }

  .filter-option input {
    accent-color: var(--accent-bright);
    flex: 0 0 auto;
  }

  .filter-option span {
    min-width: 0;
  }

  .project-container {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2em;
    width: 100%;
  }

  :global([data-project-card][hidden]) {
    display: none !important;
  }

  .empty-state {
    color: var(--text-muted);
    padding-bottom: 1rem;
  }

  .project-image-modal {
    border: none;
    position: fixed;
    inset: 0;
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    background: transparent;
    overflow: hidden;
    z-index: 999;
  }

  .project-image-modal::backdrop {
    background-color: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .project-image-modal:not([open]) {
    display: none;
  }

  .project-image-modal[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-image-frame {
    position: relative;
    width: min(92vw, 1200px);
    max-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-image-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    background: rgb(145, 64, 64);
    color: white;
    border: none;
    border-radius: 4px;
    padding: 0.4em 0.6em;
    cursor: pointer;
  }

  .project-image {
    display: block;
    max-width: 100%;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 1em;
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }

  @media screen and (max-width: 940px) {
    .content-container {
      width: 90%;
    }

    .project-container {
      grid-template-columns: 1fr;
    }

    .title-row {
      justify-content: flex-start;
    }

    .filter-toggle {
      width: 100%;
    }

    .filter-form {
      grid-template-columns: 1fr;
    }

    .filter-options-libraries {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (min-width: 1920px) {
    .content-container {
      width: min(100%, calc(var(--card-width) * 4 + 240px));
    }

    .filter-form {
      grid-template-columns: minmax(220px, 0.8fr) minmax(240px, 0.95fr) minmax(540px, 2fr);
    }

    .filter-options-libraries {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .project-container {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      --card-width: 320px;
    }
  }
  </style>
</Layout>
