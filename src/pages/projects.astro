---
import Layout from "../Layout.astro";
import { projects } from "../data.ts";
import ProjectCard from "../components/ProjectCard/ProjectCard.astro";
import ProjectsFilters from "../components/ProjectsView/ProjectsFilters.svelte";
import { getProjectFilterOptions } from "../components/ProjectsView/helpers";
import ProjectImageModalWrapper from "../components/ProjectImageModal/ProjectImageModalWrapper.svelte";

const allTech = [
  ...new Set(
    projects.flatMap((project) => [...project.languages, ...project.libraries]),
  ),
].join(", ");
const description = `Projecten van Jef (Jeffrey) van Zanten - Fullstack developer. Technologieen: ${allTech}.`;

const { categories, languages, libraries } = getProjectFilterOptions(projects);
---

<Layout title="Projects - jefvanzanten.dev" description={description}>
  <section class="projects-page">
    <div class="content-container">
      <ProjectsFilters
        client:idle
        categories={categories}
        languages={languages}
        libraries={libraries}
        totalProjects={projects.length}
      />

      <section class="project-container">
        {
          projects.map((project, index) => (
            <ProjectCard project={project} index={index} priority={index < 3} />
          ))
        }
      </section>

      <p class="empty-state" data-projects-empty hidden>
        Geen projecten gevonden met deze filters.
      </p>
    </div>

    <ProjectImageModalWrapper client:idle />
  </section>
</Layout>

<style>
  .projects-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding-bottom: 8vh;
  }

  .content-container {
    width: var(--page-content-width);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-container {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2em;
    width: 100%;
  }

  .empty-state {
    color: var(--text-muted);
    padding-bottom: 1rem;
  }

  @media screen and (max-width: 940px) {
    .content-container {
      width: 90%;
    }

    .project-container {
      grid-template-columns: 1fr;
    }
  }
</style>
