---
import Layout from "../Layout.astro";
import ProjectPage from "../components/ProjectPage/ProjectPage";
import { projects } from "../data.ts";

const allTech = [...new Set(projects.flatMap((p) => [...p.languages, ...p.libraries]))].join(", ");
const description = `Projecten van Jef (Jeffrey) van Zanten - Fullstack developer. Technologieën: ${allTech}.`;
---

<Layout
  title="Projects - jefvanzanten.dev"
  description={description}
>
  <ProjectPage client:load />
</Layout>
