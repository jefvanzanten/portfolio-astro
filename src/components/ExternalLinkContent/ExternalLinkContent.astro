---
const {
  iconUrl = "/icons/external-link.svg",
  name = "Bekijk live",
} = Astro.props;
---

<span class="content">
  <img class="icon" src={iconUrl} alt={`${name} logo`} />
  <span class="label">{name}</span>
</span>

<style>
  .content {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
  }

  .icon {
    height: 1.1rem;
    width: 1.1rem;
    object-fit: contain;
    flex-shrink: 0;
  }

  .label {
    font-size: 0.95rem;
    line-height: 1;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  @media screen and (min-width: 1024px) {
    .icon {
      height: 1rem;
      width: 1rem;
    }

    .label {
      font-size: 0.8rem;
    }
  }
</style>
